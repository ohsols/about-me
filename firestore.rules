rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAppOwner() {
      return isAuthenticated() && request.auth.uid == "HfjrcUIslZPCvNI3fxiQJVK1ebB3";
    }

    function isAdmin() {
      return isAuthenticated() && (
        isAppOwner() || 
        (request.auth.token.email in ['darkfn1234567890@gmail.com', 'calabcoleman2187@gmail.com', 'raypolebobby15@gmail.com', 'cringboi9000@gmail.com'] && 
         request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in ['admin', 'co-owner', 'owner'])
      );
    }

    function isBanned() {
      return isAuthenticated() && !isAppOwner() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('banned', false) == true;
    }

    function isValidUrl(url) {
      return url is string && (url.size() == 0 || url.matches("^https?://.*"));
    }

    function isValidUpload(data) {
      return data.keys().hasAll(['title', 'type', 'driveLink', 'imageLink']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 400 &&
             data.type in ['movie', 'anime', 'manga', 'tv'] &&
             isValidUrl(data.driveLink) &&
             isValidUrl(data.imageLink) &&
             (!('year' in data) || data.year == null || data.year is int || data.year is number) &&
             (!('rating' in data) || data.rating == null || data.rating is number) &&
             (!('quality' in data) || data.quality is string) &&
             (!('description' in data) || data.description is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAppOwner();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAppOwner();
    }

    match /allowed_admins/{docId} {
      allow read: if true;
      allow create, update, delete: if isAppOwner();
    }

    match /site_announcements/{announcementId} {
      allow read: if !isBanned();
      allow create, update, delete: if isAdmin() && !isBanned();
    }

    match /suggestions/{suggestionId} {
      allow read: if (isAdmin() || (isAuthenticated() && resource != null && resource.data.userId == request.auth.uid)) && !isBanned();
      allow create: if isAuthenticated() && !isBanned();
      allow update, delete: if isAdmin() && !isBanned();
    }

    match /chat/{message} {
      allow read: if isAuthenticated() && !isBanned();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && !isBanned();
      allow update, delete: if isAuthenticated() && (request.auth.uid == (resource != null ? resource.data.uid : "") || isAppOwner()) && !isBanned();
    }

    match /uploads/{uploadId} {
      allow read: if !isBanned();
      allow create, update: if isAdmin() && isValidUpload(request.resource.data) && !isBanned();
      allow delete: if isAdmin() && !isBanned();
    }

    match /changelogs/{logId} {
      allow read: if !isBanned();
      allow create, update, delete: if isAdmin() && !isBanned();
    }

    match /system/status {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
